        {"label": "용도", "values": ["알림 방식 설정", "전체/부분 읽기", "알림 대상 필터", "업데이트 보류"]},
        {"label": "값", "values": ["off, polite, assertive", "true, false", "additions, removals, text, all", "true, false"]},
        {"label": "지원 수준", "values": ["양호 (polite/assertive)", "제한적", "매우 제한적", "제한적"]}
      ],
      "notes": ["aria-live가 핵심이고 나머지는 보조 속성", "실제로 aria-atomic, aria-relevant, aria-busy는 지원이 일관되지 않음", "role=\"status\"는 aria-live=\"polite\"를, role=\"alert\"는 aria-live=\"assertive\"를 암묵적으로 포함"]
    }
