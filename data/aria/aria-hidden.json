{
  "id": "aria-hidden",
  "type": "state",
  "category": "widget",
  "nameKo": "보조기술에서 숨김",
  "descriptionKo": "요소와 그 자손을 접근성 트리에서 숨깁니다. 장식용 아이콘이나 중복 콘텐츠를 스크린리더에서 숨길 때 사용합니다.",
  "valueType": "true | false | undefined",
  "allowedValues": "true(숨김), false(숨기지 않음), undefined(브라우저 기본값)",
  "defaultValue": "undefined",
  "applicableTo": ["모든 요소"],
  "relatedAttrs": ["role=\"presentation\"", "role=\"none\""],
  "codeExamples": {
    "good": {
      "title": "장식용 아이콘 숨김",
      "html": "<button>\n  <span aria-hidden=\"true\">🔍</span>\n  검색\n</button>",
      "description": "장식용 이모지를 숨기고, 텍스트 '검색'만 접근 가능한 이름으로 사용합니다."
    },
    "bad": {
      "title": "포커스 가능한 요소에 aria-hidden 사용",
      "html": "<button aria-hidden=\"true\">\n  닫기\n</button>",
      "description": "포커스 가능한 요소에 aria-hidden=\"true\"를 사용하면 키보드로 접근은 되지만 스크린리더가 읽지 않아 혼란을 줍니다."
    }
  },
  "screenReaderSupport": {
    "jaws": "full",
    "nvda": "full",
    "voiceover": "full",
    "talkback": "full"
  },
  "screenReaderSpeech": {
    "context": "aria-hidden=\"true\"인 요소 도달 시",
    "jaws": "(읽지 않음 — 건너뜀)",
    "nvda": "(읽지 않음 — 건너뜀)",
    "voiceover": "(읽지 않음 — 건너뜀)",
    "talkback": "(읽지 않음 — 건너뜀)"
  },
  "wcagSC": ["1.3.1", "4.1.2"],
  "notes": "aria-hidden=\"true\"인 요소 안에 포커스 가능한 자손이 있으면 WCAG 4.1.2 위반입니다."
}
