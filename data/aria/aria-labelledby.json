{
  "id": "aria-labelledby",
  "type": "property",
  "category": "widget",
  "nameKo": "다른 요소로 이름 참조",
  "descriptionKo": "다른 요소의 텍스트 콘텐츠를 참조하여 현재 요소의 접근 가능한 이름(accessible name)을 제공합니다. aria-label과 달리 기존 텍스트를 재사용할 수 있어 유지보수에 유리합니다.",
  "valueType": "ID reference list",
  "allowedValues": "공백으로 구분된 하나 이상의 ID 참조",
  "defaultValue": "undefined",
  "applicableTo": ["모든 요소"],
  "relatedAttrs": ["aria-label", "aria-describedby"],
  "codeExamples": {
    "good": {
      "title": "dialog에 제목 연결",
      "html": "<h2 id=\"dialog-title\">로그인</h2>\n<div role=\"dialog\"\n     aria-labelledby=\"dialog-title\">\n  ...\n</div>",
      "description": "id로 연결된 h2 텍스트가 dialog의 접근 가능한 이름이 됩니다."
    },
    "bad": {
      "title": "존재하지 않는 ID 참조",
      "html": "<h2>로그인</h2>\n<div role=\"dialog\"\n     aria-labelledby=\"title\">\n  ...\n</div>",
      "description": "id=\"title\"인 요소가 없으므로 접근 가능한 이름이 빈 문자열이 됩니다."
    }
  },
  "screenReaderSupport": {
    "jaws": "full",
    "nvda": "full",
    "voiceover": "full",
    "talkback": "full"
  },
  "screenReaderSpeech": {
    "context": "role=\"dialog\"에 aria-labelledby로 h2 \"로그인\" 참조 시",
    "jaws": "\"로그인 대화 상자\"",
    "nvda": "\"로그인 대화상자\"",
    "voiceover": "\"로그인, 대화상자, 웹\"",
    "talkback": "\"로그인 대화상자\""
  },
  "wcagSC": ["1.1.1", "4.1.2"],
  "notes": "여러 ID를 공백으로 구분하여 참조하면 각 요소의 텍스트가 순서대로 결합됩니다."
}
