[
  {
    "id": "naming",
    "title": "이름/설명 제공",
    "color": "purple",
    "attrs": ["aria-label", "aria-labelledby", "aria-describedby", "aria-description"],
    "comparison": {
      "headers": ["aria-label", "aria-labelledby", "aria-describedby", "aria-description"],
      "rows": [
        {"label": "속성", "values": ["aria-label", "aria-labelledby", "aria-describedby", "aria-description"]},
        {"label": "용도", "values": ["직접 작성한 이름(핵심 이름)", "참조한 이름(핵심 이름)", "추가 설명(보조 설명)", "직접 작성한 설명(보조 설명)"]},
        {"label": "값의 형태", "values": ["텍스트 String", "참조 텍스트(id)", "참조 텍스트(id)", "텍스트 String"]},
        {"label": "특징", "values": ["화면에 보이지 않는 레이블 제공, 기존 텍스트를 완전히 대체, 짧고 명확한 이름에 적합", "이미 화면에 보이는 텍스트 활용, 여러 요소 참조 가능(공백 구분), 화면 텍스트와 일치", "이름 이후 추가로 읽힘, 보조 설명 제공, 에러/도움말 연결에 적합", "aria-describedby의 문자열 버전, 화면에 보이지 않는 설명, ARIA 1.3에서 추가"]},
        {"label": "사용 지침", "values": ["아이콘 전용 버튼, 시각적 레이블이 없는 경우, 간단한 이름 지정", "이미 있는 텍스트 활용, 여러 텍스트 조합, 다국어 영역 이름", "비밀번호 요구사항, 에러 메시지 연결, 입력 도움말", "간단한 설명이 필요한 경우, 참조할 요소가 없을 때"]},
        {"label": "우선순위", "values": ["aria-labelledby보다 낮음", "가장 높음(모든 이름 소스 중)", "이름 결정에 영향 없음", "이름 결정에 영향 없음"]}
      ],
      "notes": ["우선순위: aria-labelledby > aria-label > 기본 텍스트", "aria-labelledby는 숨겨진 요소(aria-hidden)도 참조 가능", "aria-describedby는 이름이 아닌 추가 설명으로, 스크린리더가 약간의 지연 후 읽음"]
    }
  },
  {
